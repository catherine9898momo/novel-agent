# ── 默认配置（全局兜底，未单独配置的角色使用这里的值）────
ANTHROPIC_API_KEY=sk-xxx
ANTHROPIC_BASE_URL=https://hone.vvvv.ee/
MODEL_ID=claude-sonnet-4-20250514

# ── 多模型路由配置 ──────────────────────────────────────
# 每个角色可独立配置：{ROLE}_MODEL / {ROLE}_API_KEY / {ROLE}_BASE_URL
# 不设则回退到上面的默认值
#
# ── 正文创作：Claude Sonnet（走代理）──────────────────
# WRITE_MODEL=claude-sonnet-4-20250514
# （使用默认 API_KEY 和 BASE_URL，无需单独配置）
#
# ── 规划策划：GLM（走智谱官方 Anthropic 端点）────────
# PLAN_MODEL=glm-4-plus
# PLAN_API_KEY=你的智谱auth_token
# PLAN_BASE_URL=https://open.bigmodel.cn/api/anthropic
#
# ── 章节自评：GLM（走智谱官方 Anthropic 端点）────────
# REVIEW_MODEL=glm-4-plus
# REVIEW_API_KEY=你的智谱auth_token
# REVIEW_BASE_URL=https://open.bigmodel.cn/api/anthropic
#
# ── 上下文压缩：MiniMax（走代理）────────────────────
# COMPRESS_MODEL=minimax-text-01
# （使用默认 API_KEY 和 BASE_URL，走代理即可）
#
# ── 辅助提取：GLM（走智谱官方 Anthropic 端点）────────
# EXTRACT_MODEL=glm-4-plus
# EXTRACT_API_KEY=你的智谱auth_token
# EXTRACT_BASE_URL=https://open.bigmodel.cn/api/anthropic
#
# ── 疑难分析：GPT-5（走代理，第二审稿人）────────────
# AUDIT_MODEL=gpt-5
# （使用默认 API_KEY 和 BASE_URL，走代理即可）
#
# ── 关键章升级：Claude Opus（走代理）────────────────
# OPUS_MODEL=claude-opus-4-20250514
# （使用默认 API_KEY 和 BASE_URL，走代理即可）

# ── 精准重写（仅重写薄弱段落而非整章，默认关闭）────
# 开启后：第1次不及格→精准重写补丁→重新评审，失败再全章重写
# 第3次不及格→升级至 OPUS 端点重写
# SURGICAL_REWRITE=1
